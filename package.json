{
  "name": "milk-bot",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "compile": "rimraf dist && tsc",
    "start": "yarn compile && node dist/app.js",
    "dev": "yarn compile && tsc-watch --onSuccess \"node dist/app.js\"",
    "lint": "tslint ./src/**",
    "deployCommands": "yarn compile && node dist/utils/deploycommands.js",
    "testCommands": "cross-env IS_DEBUG=true yarn deployCommands",
    "docker-build": "docker build . --tag milk-bot"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@discordjs/rest": "^0.4.1",
    "cron": "^1.8.2",
    "date-fns": "^2.28.0",
    "discord.js": "^13.3.0",
    "dotenv": "^16.0.0",
    "firebase-admin": "^10.0.2",
    "isomorphic-fetch": "^3.0.0"
  },
  "devDependencies": {
    "@types/cron": "^1.7.3",
    "cross-env": "^7.0.3",
    "prettier": "^2.3.2",
    "tsc-watch": "^5.0.3",
    "tslint": "^6.1.3",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "^4.3.5"
  }
}
